{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/runset.schema.v1.json",
  "title": "Research RunSet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runset_version",
    "datasets",
    "runs",
    "policy"
  ],
  "properties": {
    "runset_version": {
      "type": "string",
      "const": "v1"
    },
    "runset_id": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_ref"
        ],
        "properties": {
          "run_ref": {
            "type": "string",
            "minLength": 1
          },
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "canon_table_sha256": {
            "type": "string",
            "minLength": 1
          },
          "required_artifacts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "canon": {
                "type": "boolean"
              },
              "psa": {
                "type": "boolean"
              },
              "observe": {
                "type": "boolean"
              },
              "experiments": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_materialize_missing": {
          "type": "boolean"
        },
        "require_lineage_links": {
          "type": "boolean"
        },
        "require_bidirectional": {
          "type": "boolean"
        }
      }
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "datasets_sha256": {
          "type": "string",
          "minLength": 1
        },
        "runs_sha256": {
          "type": "string",
          "minLength": 1
        },
        "policy_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runset_entry_canonical_sha256": {
      "type": "string",
      "minLength": 1
    }
  }
}
