{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/project.schema.v1.json",
  "title": "Research Project Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_version", "name", "spec_dirs", "output_dir", "policy"],
  "properties": {
    "project_version": {
      "type": "string",
      "const": "v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string"
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dataset_id",
          "instrument",
          "tf",
          "session_policy",
          "schema_path",
          "colmap_path"
        ],
        "properties": {
          "dataset_id": {
            "type": "string",
            "minLength": 1
          },
          "instrument": {
            "type": "string",
            "minLength": 1
          },
          "tf": {
            "type": "string",
            "minLength": 1
          },
          "session_policy": {
            "type": "string",
            "enum": ["full", "rth", "eth"]
          },
          "rth_start": {
            "type": "string",
            "minLength": 1
          },
          "rth_end": {
            "type": "string",
            "minLength": 1
          },
          "schema_path": {
            "type": "string",
            "minLength": 1
          },
          "colmap_path": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "session_policy": {
                  "const": "rth"
                }
              },
              "required": ["session_policy"]
            },
            "then": {
              "required": ["rth_start", "rth_end"]
            }
          }
        ]
      }
    },
    "spec_dirs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fail_fast"],
      "properties": {
        "fail_fast": {
          "type": "boolean",
          "const": true
        },
        "require_observe": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "oneOf": [
    {
      "required": ["runs"],
      "not": {
        "required": ["datasets"]
      }
    },
    {
      "required": ["datasets"],
      "not": {
        "required": ["runs"]
      }
    }
  ]
}
