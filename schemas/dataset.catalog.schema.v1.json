{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/dataset.catalog.schema.v1.json",
  "title": "Research Dataset Catalog Entry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_version",
    "dataset_id",
    "kind",
    "created_utc",
    "source",
    "fingerprint",
    "dataset_entry_canonical_sha256"
  ],
  "properties": {
    "dataset_version": {
      "type": "string",
      "const": "v1"
    },
    "dataset_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "raw_vendor_v1",
        "canon_v1"
      ]
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "tz": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "files",
        "file_count",
        "total_bytes"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "bytes",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "bytes": {
                "type": "integer",
                "minimum": 0
              },
              "sha256": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_sha256"
      ],
      "properties": {
        "files_sha256": {
          "type": "string",
          "minLength": 1
        },
        "canon_table_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dataset_entry_canonical_sha256": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "canon_v1"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "required": [
          "tz"
        ],
        "properties": {
          "tz": {
            "const": "America/New_York"
          },
          "fingerprint": {
            "required": [
              "files_sha256",
              "canon_table_sha256"
            ]
          }
        }
      }
    }
  ]
}