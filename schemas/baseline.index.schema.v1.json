{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/baseline.index.schema.v1.json",
  "title": "Research Baseline Index v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "index_version",
    "created_utc",
    "runsets"
  ],
  "properties": {
    "index_version": {
      "type": "string",
      "const": "v1"
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "runsets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "baseline_id",
          "card_sha256",
          "manifest_canonical_sha256",
          "path"
        ],
        "properties": {
          "baseline_id": {
            "type": "string",
            "minLength": 1
          },
          "card_sha256": {
            "type": "string",
            "minLength": 1
          },
          "manifest_canonical_sha256": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
