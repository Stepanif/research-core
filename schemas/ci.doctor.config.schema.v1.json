{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/ci.doctor.config.schema.v1.json",
  "title": "Research CI Doctor Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "doctor_version",
    "catalog_dir",
    "baseline_root",
    "runsets_path",
    "out_dir",
    "checks"
  ],
  "properties": {
    "doctor_version": {
      "type": "string",
      "const": "v1"
    },
    "catalog_dir": {
      "type": "string",
      "minLength": 1
    },
    "baseline_root": {
      "type": "string",
      "minLength": 1
    },
    "runsets_path": {
      "type": "string",
      "minLength": 1
    },
    "out_dir": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "default": "prod"
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verify_baseline_root",
        "verify_promotions",
        "verify_runsets"
      ],
      "properties": {
        "verify_baseline_root": {
          "type": "boolean",
          "const": true
        },
        "verify_promotions": {
          "type": "boolean",
          "const": true
        },
        "verify_runsets": {
          "type": "boolean",
          "const": true
        },
        "verify_bundles": {
          "type": "boolean",
          "default": false
        },
        "verify_dashboard": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "bundles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "zip"
        ],
        "properties": {
          "zip": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_path",
        "manifest_path"
      ],
      "properties": {
        "summary_path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
