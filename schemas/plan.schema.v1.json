{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/plan.schema.v1.json",
  "title": "Research Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_version", "created_utc", "project_id", "tasks"],
  "properties": {
    "plan_version": {
      "type": "string",
      "const": "v1"
    },
    "created_utc": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "kind",
          "run_dir",
          "spec_dir",
          "out_dir",
          "argv",
          "deps",
          "expected_outputs"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["experiment_batch"]
          },
          "run_dir": {
            "type": "string",
            "minLength": 1
          },
          "spec_dir": {
            "type": "string",
            "minLength": 1
          },
          "out_dir": {
            "type": "string",
            "minLength": 1
          },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "deps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_outputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
