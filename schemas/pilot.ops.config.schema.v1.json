{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research/pilot.ops.config.schema.v1.json",
  "title": "Research Pilot Ops Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pilot_ops_version",
    "catalog_dir",
    "datasets_path",
    "baseline_root",
    "label",
    "out_dir",
    "runset_kind",
    "require_promoted_baseline",
    "doctor_out_subdir",
    "drift_out_subdir"
  ],
  "properties": {
    "pilot_ops_version": {
      "type": "string",
      "const": "v1"
    },
    "catalog_dir": {
      "type": "string",
      "minLength": 1
    },
    "datasets_path": {
      "type": "string",
      "minLength": 1
    },
    "baseline_root": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "default": "prod"
    },
    "out_dir": {
      "type": "string",
      "minLength": 1
    },
    "runset_kind": {
      "type": "string",
      "const": "explicit_from_index"
    },
    "require_promoted_baseline": {
      "type": "boolean",
      "const": true,
      "default": true
    },
    "doctor_out_subdir": {
      "type": "string",
      "minLength": 1,
      "default": "doctor"
    },
    "drift_out_subdir": {
      "type": "string",
      "minLength": 1,
      "default": "drift"
    }
  }
}
